# Server environment example

# --- AI provider configuration ---
# Use "ollama" to run local AI (recommended if you do not want OpenAI)
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b-instruct

# --- Optional OpenAI configuration (only used when AI_PROVIDER=openai) ---
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
